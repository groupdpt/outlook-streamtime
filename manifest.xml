<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:type="MailApp">

  <Id>b2c3d4e5-f6a7-8901-bcde-f12345678901</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Your Company</ProviderName>
  <DefaultLocale>en-GB</DefaultLocale>
  <DisplayName DefaultValue="Streamtime Jobs"/>
  <Description DefaultValue="Search Streamtime jobs and set them as your email subject."/>

  <!-- Replace the URL below with your GitHub Pages URL once deployed -->
  <IconUrl DefaultValue="https://groupdpt.github.io/outlook-streamtime/icon-64.png"/>
  <HighResolutionIconUrl DefaultValue="https://groupdpt.github.io/outlook-streamtime/icon-64.png"/>
  <SupportUrl DefaultValue="https://groupdpt.github.io/outlook-streamtime"/>

  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit"/>
  </Rule>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets DefaultMinVersion="1.3">
      <Set Name="Mailbox" MinVersion="1.3"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <!-- Replace with your GitHub Pages URL -->
        <SourceLocation DefaultValue="https://groupdpt.github.io/outlook-streamtime/taskpane.html"/>
        <RequestedHeight>400</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

</OfficeApp>
